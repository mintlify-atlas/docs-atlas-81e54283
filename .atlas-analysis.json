  "keyFeatures": [
    "Household creation and member invitations",
    "Chores tracking with assignees and recurrence",
    "Bill tracking with payment logging",
    "Shopping list management with categories",
    "Maintenance task logging",
    "Notifications and activity feed",
    "Role-based access control",
    "Audit logs for accountability"
  ],
  "publicApiSurface": [
    "GET /api/chores - Fetch household chores",
    "POST /api/chores - Create new chore",
    "PUT /api/chores/update - Update chore",
    "DELETE /api/chores/delete - Delete chore",
    "GET /api/bills - Fetch bills",
    "POST /api/bills - Create new bill",
    "GET /api/bills/monthly - Get monthly bill summary",
    "GET /api/shopping - Fetch shopping items",
    "POST /api/shopping - Create shopping item",
    "GET /api/maintenance - Fetch maintenance tasks",
    "POST /api/maintenance - Create maintenance task",
    "GET /api/household/members - Get household members",
    "POST /api/household/init - Initialize household",
    "POST /api/household/accept - Accept invitation",
    "GET /api/notifications - Fetch notifications",
    "POST /api/notifications/clear - Mark all notifications as read",
    "GET /api/audit-log - Fetch audit logs"
  ]
}
